{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "lib": ["es2024"],
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "mocha"],
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true
  }
}
